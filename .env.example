# Database
DATABASE_URL=postgres://clawvet:clawvet@localhost:5432/clawvet

# Redis (for BullMQ scan queue)
REDIS_URL=redis://localhost:6379

# Semantic analysis pass (optional) — bring your own LLM key. The provider is
# auto-selected from whichever key is set, or forced via CLAWVET_LLM_PROVIDER.
# ClawVet never ships a key; you supply one.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ZHIPU_API_KEY=...
# CLAWVET_LLM_PROVIDER=anthropic   # anthropic | openai | zhipu (optional override)
# CLAWVET_LLM_MODEL=claude-sonnet-4-6   # optional model override
#
# Local models via Ollama (no code needed — it speaks the OpenAI API):
#   CLAWVET_LLM_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   CLAWVET_LLM_MODEL=llama3.1

# GitHub OAuth (for user auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/v1/auth/github/callback

# JWT secret for session tokens (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Web app URL (for OAuth redirect)
WEB_URL=http://localhost:3000

# API
PORT=3001
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100

# Next.js web app
API_URL=http://localhost:3001
